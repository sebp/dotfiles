{{ if eq .chezmoi.os "linux" -}}
[".dircolors"]
    type = "file"
    url = "https://github.com/dracula/dircolors/raw/main/.dircolors"
    refreshPeriod = "168h"

[".config/tmux/plugins/tpm"]
    type = "archive"
    url = "https://github.com/tmux-plugins/tpm/archive/refs/heads/master.zip"
    exact = true
    stripComponents = 1
    refreshPeriod = "168h"

[".config/tilix/schemes/Dracula.json"]
    type = "file"
    url = "https://raw.githubusercontent.com/dracula/tilix/master/Dracula.json"
    refreshPeriod = "168h"

[".local/bin/delta"]
    type = "file"
    url = "https://github.com/dandavison/delta/releases/download/0.19.2/delta-0.19.2-x86_64-unknown-linux-musl.tar.gz"
    executable = true
    refreshPeriod = "168h"
    [".local/bin/delta".filter]
        command = "tar"
        args = ["--extract", "--file", "/dev/stdin", "--gzip", "--to-stdout", "delta-0.19.2-x86_64-unknown-linux-musl/delta"]

[".local/bin/dust"]
    type = "file"
    url = "https://github.com/bootandy/dust/releases/download/v1.2.4/dust-v1.2.4-x86_64-unknown-linux-musl.tar.gz"
    executable = true
    refreshPeriod = "168h"
    [".local/bin/dust".filter]
        command = "tar"
        args = ["--extract", "--file", "/dev/stdin", "--gzip", "--to-stdout", "dust-v1.2.4-x86_64-unknown-linux-musl/dust"]
{{- end }}

[".local/share/nvim/site/autoload/plug.vim"]
    type = "file"
    url = "https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim"
    refreshPeriod = "168h"

[".agents/skills/create-agentsmd/SKILL.md"]
    type = "file"
    url = "https://raw.githubusercontent.com/github/awesome-copilot/e9c8e3704181fa38245d101308a8527d12af6a4d/skills/create-agentsmd/SKILL.md"
    refreshPeriod = "672h"

[".agents/skills/requesting-code-review/SKILL.md"]
    type = "file"
    url = "https://raw.githubusercontent.com/obra/superpowers/896224c4b1879920ab573417e68fd51d2ccc9072/skills/requesting-code-review/SKILL.md"
    refreshPeriod = "672h"

[".agents/skills/requesting-code-review/code-reviewer.md"]
    type = "file"
    url = "https://raw.githubusercontent.com/obra/superpowers/896224c4b1879920ab573417e68fd51d2ccc9072/skills/requesting-code-review/code-reviewer.md"
    refreshPeriod = "672h"

[".agents/skills/mermaid-diagrams"]
    type = "archive"
    url = "https://github.com/softaworks/agent-toolkit/archive/3027f20f3181758385a1bb8c022d4041dfb4de84.tar.gz"
    exact = true
    stripComponents = 3
    include = ["*/skills/mermaid-diagrams/**"]
    refreshPeriod = "672h"

